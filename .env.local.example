NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=your_openai_api_key

# Cloud Run sets PORT automatically (default 8080). For local dev:
# PORT=8080

# Deployment notes:
# - NEXT_PUBLIC_* must be passed as Docker --build-arg at image build time
# - OPENAI_API_KEY and SUPABASE_SERVICE_ROLE_KEY are runtime secrets only
# - See DEPLOY_GCP.md for full Cloud Run deployment instructions
